---
// Footer with navigation links and legal info
---

<footer class="bg-navy-950 text-gray-300 mt-20">
  <div class="container-main py-12">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
      <!-- Brand -->
      <div class="md:col-span-1">
        <a href="/" class="flex items-center gap-2 mb-4">
          <span class="text-2xl">📊</span>
          <span class="text-lg font-bold text-white">Best CPA Near Me</span>
        </a>
        <p class="text-sm text-gray-400 leading-relaxed">
          Connecting individuals and businesses with trusted Certified Public Accountants across the United States.
        </p>
      </div>

      <!-- About Links -->
      <div>
        <h4 class="text-sm font-semibold text-white uppercase tracking-wider mb-4">About</h4>
        <ul class="space-y-2">
          <li><a href="/about/" class="text-sm hover:text-white transition-colors">About Us</a></li>
          <li><a href="/contact/" class="text-sm hover:text-white transition-colors">Contact</a></li>
          <li><a href="/how-it-works/" class="text-sm hover:text-white transition-colors">How It Works</a></li>
          <li><a href="/for-cpas/" class="text-sm hover:text-white transition-colors">For CPAs</a></li>
        </ul>
      </div>

      <!-- Resources -->
      <div>
        <h4 class="text-sm font-semibold text-white uppercase tracking-wider mb-4">Resources</h4>
        <ul class="space-y-2">
          <li><a href="/find-cpa/" class="text-sm hover:text-white transition-colors">Find a CPA</a></li>
          <li><a href="/texas/" class="text-sm hover:text-white transition-colors">CPAs in Texas</a></li>
          <li><a href="/california/" class="text-sm hover:text-white transition-colors">CPAs in California</a></li>
          <li><a href="/new-york/" class="text-sm hover:text-white transition-colors">CPAs in New York</a></li>
        </ul>
      </div>

      <!-- Legal -->
      <div>
        <h4 class="text-sm font-semibold text-white uppercase tracking-wider mb-4">Legal</h4>
        <ul class="space-y-2">
          <li><a href="/privacy-policy/" class="text-sm hover:text-white transition-colors">Privacy Policy</a></li>
          <li><a href="/terms-of-service/" class="text-sm hover:text-white transition-colors">Terms of Service</a></li>
          <li><a href="/disclaimer/" class="text-sm hover:text-white transition-colors">Disclaimer</a></li>
        </ul>
      </div>
    </div>

    <div class="border-t border-gray-800 mt-8 pt-8 text-center">
      <p class="text-sm text-gray-500">
        &copy; {new Date().getFullYear()} Best CPA Near Me. All rights reserved.
      </p>
      <p class="text-xs text-gray-600 mt-2">
        This website is for informational purposes only and does not constitute financial or legal advice.
      </p>
    </div>
  </div>
</footer>
