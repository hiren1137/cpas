---
// Homepage Hero — main CTA section
---

<section class="relative bg-gradient-to-br from-navy-900 via-navy-800 to-navy-950 text-white overflow-hidden">
  <!-- Background pattern -->
  <div class="absolute inset-0 opacity-10">
    <div class="absolute inset-0" style="background-image: radial-gradient(circle at 25% 25%, rgba(255,255,255,0.1) 1px, transparent 1px); background-size: 40px 40px;"></div>
  </div>

  <div class="container-main relative py-20 md:py-28 lg:py-32">
    <div class="max-w-3xl mx-auto text-center">
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold leading-tight mb-6">
        Find the Best <span class="text-amber-400">CPAs</span> Near You
      </h1>
      <p class="text-lg md:text-xl text-gray-300 mb-10 leading-relaxed max-w-2xl mx-auto">
        Connect with verified Certified Public Accountants across all 50 states. Get expert tax preparation, accounting services, and financial guidance — all in one place.
      </p>

      <div class="flex flex-col sm:flex-row gap-4 justify-center mb-12">
        <a href="/find-cpa/" class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-amber-500 text-navy-950 font-bold rounded-lg hover:bg-amber-400 transition-all duration-200 shadow-lg hover:shadow-xl text-lg">
          Find a CPA <span>→</span>
        </a>
        <a href="/about/" class="inline-flex items-center justify-center gap-2 px-8 py-4 border-2 border-white/30 text-white font-semibold rounded-lg hover:bg-white/10 transition-all duration-200 text-lg">
          Learn More
        </a>
      </div>

      <!-- Trust stats -->
      <div class="flex flex-col sm:flex-row items-center justify-center gap-8 text-sm">
        <div class="flex items-center gap-2">
          <span class="text-amber-400 text-xl">✓</span>
          <span class="text-gray-300"><strong class="text-white">5,000+</strong> Verified CPAs</span>
        </div>
        <div class="hidden sm:block w-px h-6 bg-white/20"></div>
        <div class="flex items-center gap-2">
          <span class="text-amber-400 text-xl">🏛️</span>
          <span class="text-gray-300"><strong class="text-white">50</strong> States Covered</span>
        </div>
        <div class="hidden sm:block w-px h-6 bg-white/20"></div>
        <div class="flex items-center gap-2">
          <span class="text-amber-400 text-xl">⭐</span>
          <span class="text-gray-300"><strong class="text-white">4.8</strong> Avg Rating</span>
        </div>
      </div>
    </div>
  </div>

  <!-- Wave bottom -->
  <div class="absolute bottom-0 left-0 right-0">
    <svg viewBox="0 0 1440 60" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full">
      <path d="M0 60V30C240 0 480 0 720 30C960 60 1200 60 1440 30V60H0Z" fill="white"/>
    </svg>
  </div>
</section>
