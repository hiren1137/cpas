---
// FirmList — renders list of FirmCards or placeholder
import type { Firm } from '../../lib/types';
import FirmCard from './FirmCard.astro';

export interface Props {
  firms: Firm[];
  stateSlug: string;
  citySlug: string;
  cityName: string;
}
const { firms, stateSlug, citySlug, cityName } = Astro.props;
---

<section class="py-12">
  <div class="container-main">
    {firms.length > 0 ? (
      <div class="space-y-4">
        {firms.slice(0, 10).map(firm => (
          <FirmCard firm={firm} stateSlug={stateSlug} citySlug={citySlug} />
        ))}
      </div>
    ) : (
      <div class="card p-10 text-center max-w-xl mx-auto">
        <div class="text-4xl mb-4">📋</div>
        <h3 class="text-xl font-semibold text-navy-900 mb-2">Directory Coming Soon</h3>
        <p class="text-gray-600 mb-6">
          We're currently building our CPA directory for {cityName}. Be the first to know when listings are available.
        </p>
        <form class="flex flex-col sm:flex-row gap-3 max-w-sm mx-auto">
          <input type="email" placeholder="Enter your email" class="flex-1 px-4 py-2.5 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-navy-500 focus:border-transparent" />
          <button type="submit" class="btn-primary text-sm !py-2.5">Notify Me</button>
        </form>
      </div>
    )}
  </div>
</section>
