---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';

const title = 'Contact Us — Best CPA Near Me';
const description = 'Get in touch with the Best CPA Near Me team. We are here to help you find the right CPA for your accounting and tax needs.';
const canonical = 'https://bestcpanearme.com/contact/';
---

<BaseLayout title={title} description={description} canonical={canonical}>
  <div class="container-main py-12">
    <Breadcrumbs items={[{ label: 'Home', href: '/' }, { label: 'Contact' }]} />
    <div class="max-w-3xl">
      <h1 class="text-3xl md:text-4xl font-extrabold text-navy-900 mb-6">Contact Us</h1>
      <p class="text-lg text-gray-600 mb-8">Have questions or feedback? We'd love to hear from you. Reach out to us via email.</p>
      <div class="card p-8">
        <p class="text-gray-700">📧 Email: <a href="mailto:techjits.com@gmail.com" class="text-navy-800 font-semibold hover:underline">techjits.com@gmail.com</a></p>
      </div>
    </div>
  </div>
</BaseLayout>
