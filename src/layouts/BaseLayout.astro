---
// BaseLayout — wraps every page with SEO head, header, footer
import SEO from '../components/SEO.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

export interface Props {
  title: string;
  description: string;
  canonical: string;
  ogType?: string;
  ogImage?: string;
  schema?: string;
}

const { title, description, canonical, ogType, ogImage, schema } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <!-- Google Analytics -->
  <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-LWBHMVX6M7"></script>
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-LWBHMVX6M7');
  </script>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <meta name="google-site-verification" content="xU05f5H7v3AVplIsvH5VBv0NnMlD-yUuOeXDrzwlzp8" />
  <SEO title={title} description={description} canonical={canonical} ogType={ogType} ogImage={ogImage} />
  {schema && <script type="application/ld+json" set:html={schema} />}
</head>
<body class="min-h-screen flex flex-col">
  <Header />
  <main class="flex-1">
    <slot />
  </main>
  <Footer />
</body>
</html>
